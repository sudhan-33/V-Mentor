{
  "name": "vmentor",
  "version": "0.1.0",
  "private": true,
  "description": "VMentor — Mentor Discovery & Booking Platform (monorepo)",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build -w @vmentor/shared",
    "dev": "npm run build:shared && npm run dev -w @vmentor/api",
    "dev:api": "npm run build:shared && npm run dev -w @vmentor/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run build:shared && npm run typecheck --workspaces --if-present",
    "db:migrate": "npm run migrate -w @vmentor/api"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
